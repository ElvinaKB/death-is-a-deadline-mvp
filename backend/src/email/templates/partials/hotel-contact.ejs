<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin: 0 0 24px; border: 1px solid #f0ebe3; border-radius: 10px; overflow: hidden;">
  <tr>
    <td colspan="2" class="details-header" style="background-color: #faf8f4; padding: 14px 20px; border-bottom: 1px solid #f0ebe3;">
      <p style="margin: 0; font-size: 13px; font-weight: 700; color: #92400e; text-transform: uppercase; letter-spacing: 0.6px;">
        Hotel Contact Information
      </p>
    </td>
  </tr>
  <% if (placeFullAddress) { %>
  <tr>
    <td class="detail-label<%= !placeContactEmail && !placeContactPhone ? ' detail-label-last' : '' %>" style="padding: 13px 20px; font-size: 14px; color: #6b7280;<%= placeContactEmail || placeContactPhone ? ' border-bottom: 1px solid #f5f0e8;' : '' %> width: 42%; vertical-align: top;">Address</td>
    <td class="detail-value<%= !placeContactEmail && !placeContactPhone ? ' detail-value-last' : '' %>" style="padding: 13px 20px; font-size: 14px; color: #374151; font-weight: 500; text-align: right; word-break: break-word; vertical-align: top;<%= placeContactEmail || placeContactPhone ? ' border-bottom: 1px solid #f5f0e8;' : '' %>">
      <%= placeFullAddress %>
      <% if (mapsUrl) { %>
      <br />
      <a href="<%= mapsUrl %>" style="display: inline-block; margin-top: 8px; font-size: 13px; font-weight: 600; color: #e5a823; text-decoration: none;">
        Get directions &rarr;
      </a>
      <% } %>
    </td>
  </tr>
  <% } %>
  <% if (placeContactEmail) { %>
  <tr>
    <td class="detail-label<%= !placeContactPhone ? ' detail-label-last' : '' %>" style="padding: 13px 20px; font-size: 14px; color: #6b7280;<%= placeContactPhone ? ' border-bottom: 1px solid #f5f0e8;' : '' %> vertical-align: top;">Email</td>
    <td class="detail-value<%= !placeContactPhone ? ' detail-value-last' : '' %>" style="padding: 13px 20px; font-size: 14px; font-weight: 500; text-align: right; word-break: break-all; vertical-align: top;<%= placeContactPhone ? ' border-bottom: 1px solid #f5f0e8;' : '' %>">
      <a href="mailto:<%= placeContactEmail %>" style="color: #374151; text-decoration: none;"><%= placeContactEmail %></a>
    </td>
  </tr>
  <% } %>
  <% if (placeContactPhone) { %>
  <tr>
    <td class="detail-label detail-label-last" style="padding: 13px 20px; font-size: 14px; color: #6b7280; vertical-align: top;">Phone</td>
    <td class="detail-value detail-value-last" style="padding: 13px 20px; font-size: 14px; font-weight: 500; text-align: right; vertical-align: top;">
      <a href="tel:<%= placeContactPhone %>" style="color: #374151; text-decoration: none;"><%= placeContactPhone %></a>
    </td>
  </tr>
  <% } %>
</table>
