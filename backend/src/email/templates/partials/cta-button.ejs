<table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center" class="cta-wrapper" style="margin: 0 auto 24px; width: 100%; max-width: 320px;">
  <tr>
    <td class="cta-cell" align="center" style="border-radius: 8px; background: linear-gradient(135deg, #c9921a 0%, #e5a823 100%);">
      <a href="<%= url %>" class="cta-link" style="display: inline-block; padding: 14px 32px; font-size: 15px; font-weight: 700; color: #0a0a0a; text-decoration: none; letter-spacing: 0.3px;">
        <%= label %>
      </a>
    </td>
  </tr>
</table>
