# Local preview only — set VITE_PREVIEW_BYPASS=true in .env.local (see PREVIEW_BYPASS_REVERT.txt)
VITE_PREVIEW_BYPASS=false

# API
VITE_API_BASE_URL=http://localhost:4000

# Supabase
VITE_APP_SUPABASE_BUCKET=student-id-cards
VITE_APP_SUPABASE_URL=https://[project-ref].supabase.co
VITE_APP_SUPABASE_ANON_KEY=your_supabase_anon_key

# Stripe
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Mapbox
VITE_APP_MAPBOX=your_mapbox_public_token

# Cloudflare Turnstile (contact form)
# Local dev: leave unset — app uses Cloudflare test widget (always passes, no backend needed).
# Production: set your real Site Key. Secret Key goes on backend only (TURNSTILE_SECRET_KEY).
# VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key
# VITE_TURNSTILE_DEMO=false
# VITE_CONTACT_DEMO_MODE=false

# Analytics (set on Vercel for preview/production)
VITE_GA4_MEASUREMENT_ID=G-XD0FGWCLW0
VITE_CLARITY_PROJECT_ID=wrqknl9614
VITE_META_PIXEL_ID=2238279313671965
